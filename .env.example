# App
HOST=127.0.0.1
PORT=8000

# Providers (comma-separated IDs: openai_whisper, whisper_local, deepgram, google, xai_grok)
ENABLED_PROVIDERS=openai_whisper, deepgram, google, xai_grok

# Limits
MAX_UPLOAD_MB=25
MAX_AUDIO_DURATION_SEC=300
PROVIDER_TIMEOUT_SEC=120

# OpenAI Whisper (default provider)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: local faster-whisper (no API key; enable with ENABLED_PROVIDERS=whisper_local)
WHISPER_MODEL=base
WHISPER_DEVICE=cpu

# Other cloud providers (optional)
DEEPGRAM_API_KEY=
# Google Cloud STT — absolute path to a service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=
# Required for audio longer than ~60s (Google inline limit)
GOOGLE_STORAGE_BUCKET=
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
