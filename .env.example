# App
HOST=127.0.0.1
PORT=8000
# VITE_SOCKET_PATH defaults to the OS temp directory.

# Providers (comma-separated IDs: openai_whisper, deepgram, google, xai_grok)
ENABLED_PROVIDERS=openai_whisper,deepgram,google,xai_grok

# Limits
MAX_UPLOAD_MB=25
MAX_AUDIO_DURATION_SEC=900
PROVIDER_TIMEOUT_SEC=120
PROVIDER_MAX_ATTEMPTS=3
PROVIDER_RETRY_BASE_DELAY_SEC=1.0
PROVIDER_RETRY_MAX_DELAY_SEC=8.0
OPENAI_DIARIZE_TIMEOUT_SEC=600
GOOGLE_BATCH_TIMEOUT_SEC=600

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE=stt-arena.log
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=5

# OpenAI Whisper (default provider)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Model selection (defaults are each provider's latest)
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
OPENAI_DIARIZE_MODEL=gpt-4o-transcribe-diarize
DEEPGRAM_MODEL=nova-3
GOOGLE_SPEECH_MODEL=chirp_3
GOOGLE_SPEECH_REGION=us

# Other cloud providers (optional)
DEEPGRAM_API_KEY=
# Google Cloud STT — absolute path to a service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=
# Required for audio longer than ~60s (Google inline limit)
GOOGLE_STORAGE_BUCKET=
# xAI Grok
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1

# Billing plans (see GET /api/billing/plans for valid plan IDs)
BILLING_PLAN_OPENAI_WHISPER=gpt-4o-transcribe
BILLING_PLAN_DEEPGRAM=nova-3-batch-payg
BILLING_PLAN_GOOGLE=google-v2-standard-tier1
BILLING_PLAN_XAI_GROK=xai-stt-batch

# Minutes already used this calendar month (for free-tier / volume-tier estimates)
BILLING_MONTHLY_MINUTES_OPENAI_WHISPER=0
BILLING_MONTHLY_MINUTES_DEEPGRAM=0
BILLING_MONTHLY_MINUTES_GOOGLE=0
BILLING_MONTHLY_MINUTES_XAI_GROK=0
