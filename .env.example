# App
HOST=127.0.0.1
PORT=8000

# Providers (comma-separated IDs)
ENABLED_PROVIDERS=whisper_local

# Limits
MAX_UPLOAD_MB=25
MAX_AUDIO_DURATION_SEC=300
PROVIDER_TIMEOUT_SEC=120

# Local Whisper
WHISPER_MODEL=base
WHISPER_DEVICE=cpu

# Cloud providers (optional)
DEEPGRAM_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
